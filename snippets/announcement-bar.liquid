{% comment %}
  Bakery Order Window — Announcement Bar Snippet
  Include in layout/theme.liquid inside <body>, before main content.

  Usage:
    {% render 'announcement-bar' %}

  The JS in order-window.js will populate and style this bar based on window state.
  We render it empty server-side to avoid flash of unstyled content.
{% endcomment %}

{%- liquid
  assign window_open = false
  assign bakery_mf = shop.metafields['bakery']['window_open']
  if bakery_mf != blank and bakery_mf.value == true
    assign window_open = true
  endif
-%}

<style>
  .bakery-announcement-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.02em;
    position: relative;
    z-index: 100;
    transition: background-color 0.3s;
  }
  .bakery-announcement-bar--open {
    background-color: #2d5a27;
    color: #ffffff;
  }
  .bakery-announcement-bar--urgent {
    background-color: #8b4513;
    color: #fff8f0;
  }
  .bakery-announcement-bar--closed {
    background-color: #3d2b1f;
    color: #c9a057;
  }
  .bakery-bar__dot--open  { color: #7fff7f; }
  .bakery-bar__dot--urgent { color: #ffd700; }
  .bakery-bar__dot--closed { color: #ff6b6b; }
  .bakery-bar__link {
    color: inherit;
    text-decoration: underline;
    margin-left: 4px;
  }
  .bakery-bar__link:hover { opacity: 0.85; }
</style>

{%- comment %} Server-side initial render to prevent flash {% endcomment %}
<div
  id="bakery-announcement-bar"
  class="bakery-announcement-bar {% if window_open %}bakery-announcement-bar--open{% else %}bakery-announcement-bar--closed{% endif %}"
  role="banner"
  aria-live="polite"
>
  {% if window_open %}
    <span class="bakery-bar__dot bakery-bar__dot--open">●</span>
    Orders open — Order by <strong>&nbsp;Wednesday 11:59pm&nbsp;</strong> for Friday/Saturday delivery
  {% else %}
    <span class="bakery-bar__dot bakery-bar__dot--closed">●</span>
    Orders closed — next window opens Sunday.
    <a href="/pages/waitlist" class="bakery-bar__link">Join the waitlist →</a>
  {% endif %}
</div>

{%- comment %} Bootstrap the JS with server-side metafield truth {% endcomment %}
<script>
  window.BAKERY_WINDOW = { open: {{ window_open | json }} };
</script>
{{ 'order-window.js' | asset_url | script_tag }}
